{
  "extends": "US-039/style-tokens.json",
  "description": "US-041 Quick Match — extends existing dark design system",
  "colors": {
    "bg":               "#0A0A0A",
    "surface":          "#141414",
    "surfaceElevated":  "#1F1F1F",
    "border":           "#2C2C2C",
    "accent":           "#FF5500",
    "accentHover":      "#E64D00",
    "accentDim":        "rgba(255, 85, 0, 0.12)",
    "textPrimary":      "#FFFFFF",
    "textSecondary":    "#9A9A9A",
    "textPlaceholder":  "#484848",
    "error":            "#FF4444",
    "errorBg":          "rgba(255, 68, 68, 0.10)",
    "errorBorder":      "rgba(255, 68, 68, 0.25)",
    "success":          "#22C55E",
    "successBg":        "rgba(34, 197, 94, 0.10)",
    "successBorder":    "rgba(34, 197, 94, 0.25)",
    "ghost":            "#F59E0B",
    "ghostBg":          "rgba(245, 158, 11, 0.10)",
    "ghostBorder":      "rgba(245, 158, 11, 0.25)",
    "team1":            "#FF5500",
    "team1Bg":          "rgba(255, 85, 0, 0.08)",
    "team1Border":      "rgba(255, 85, 0, 0.22)",
    "team2":            "#0EA5E9",
    "team2Bg":          "rgba(14, 165, 233, 0.08)",
    "team2Border":      "rgba(14, 165, 233, 0.22)",
    "infoBg":           "rgba(14, 165, 233, 0.08)",
    "infoBorder":       "rgba(14, 165, 233, 0.22)",
    "infoText":         "#0EA5E9"
  },
  "typography": {
    "family":  "Inter",
    "scale": {
      "xs":   "11px",
      "sm":   "13px",
      "base": "15px",
      "lg":   "18px",
      "xl":   "24px",
      "2xl":  "32px"
    },
    "weights": {
      "regular": 400,
      "medium":  500,
      "bold":    700,
      "black":   900
    }
  },
  "spacing": {
    "1": "4px",  "2": "8px",  "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px",
    "12": "48px"
  },
  "borderRadius": {
    "sm":   "6px",
    "md":   "10px",
    "lg":   "14px",
    "full": "9999px"
  },
  "components": {
    "stepper": {
      "dotSize":       "28px",
      "dotActive":     "colors.accent",
      "dotDone":       "colors.surface with accent border",
      "dotInactive":   "colors.surfaceElevated",
      "lineColor":     "colors.border",
      "labelActive":   "colors.textPrimary",
      "labelInactive": "colors.textSecondary"
    },
    "sportCard": {
      "bg":             "colors.surface",
      "border":         "colors.border",
      "borderSelected": "colors.accent",
      "bgSelected":     "colors.accentDim",
      "borderRadius":   "borderRadius.lg",
      "padding":        "spacing.4"
    },
    "playerSlot": {
      "emptyBg":        "colors.surfaceElevated",
      "emptyBorder":    "dashed 1px colors.border",
      "filledTeam1":    "colors.team1Border",
      "filledTeam2":    "colors.team2Border",
      "borderRadius":   "borderRadius.lg"
    },
    "suggestionChip": {
      "bg":             "colors.surface",
      "border":         "colors.border",
      "bgUsed":         "colors.surfaceElevated",
      "borderRadius":   "borderRadius.md",
      "avatarSize":     "36px"
    },
    "circlePicker": {
      "bg":             "colors.surface",
      "border":         "colors.border",
      "borderHover":    "colors.accent",
      "borderRadius":   "borderRadius.lg"
    },
    "infoBanner": {
      "bg":             "colors.infoBg",
      "border":         "colors.infoBorder",
      "color":          "colors.infoText",
      "borderRadius":   "borderRadius.md"
    }
  }
}
