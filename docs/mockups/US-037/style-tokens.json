{
  "extends": "US-005/style-tokens.json",
  "colors": {
    "deltaPositive":      "#22C55E",
    "deltaPositiveBg":    "rgba(34, 197, 94, 0.10)",
    "deltaNegative":      "#FF4444",
    "deltaNegativeBg":    "rgba(255, 68, 68, 0.10)",
    "forcedBadge":        "#8B5CF6",
    "forcedBadgeBg":      "rgba(139, 92, 246, 0.10)",
    "forcedBadgeBorder":  "rgba(139, 92, 246, 0.25)"
  },
  "components": {
    "decisionStrip": {
      "bg":           "colors.surfaceElevated",
      "border":       "colors.border",
      "borderRadius": "borderRadius.md",
      "padding":      "spacing.3 spacing.4"
    },
    "deltaChip": {
      "borderRadius": "borderRadius.full",
      "fontSize":     "typography.scale.sm",
      "fontWeight":   "typography.weights.black",
      "padding":      "spacing.1 spacing.3",
      "positiveColor": "colors.deltaPositive",
      "positiveBg":    "colors.deltaPositiveBg",
      "negativeColor": "colors.deltaNegative",
      "negativeBg":    "colors.deltaNegativeBg"
    },
    "forcedBadge": {
      "color":         "colors.forcedBadge",
      "bg":            "colors.forcedBadgeBg",
      "border":        "colors.forcedBadgeBorder",
      "borderRadius":  "borderRadius.full",
      "fontSize":      "typography.scale.xs"
    },
    "playerDeltaRow": {
      "bg":           "colors.surface",
      "border":       "colors.border",
      "borderRadius": "borderRadius.md",
      "padding":      "spacing.3 spacing.4"
    }
  }
}
