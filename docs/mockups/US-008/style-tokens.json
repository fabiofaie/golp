{
  "extends": "US-005/style-tokens.json",
  "colors": {
    "bg":               "#0A0A0A",
    "surface":          "#141414",
    "surfaceElevated":  "#1F1F1F",
    "border":           "#2C2C2C",
    "accent":           "#FF5500",
    "accentHover":      "#E64D00",
    "accentDim":        "rgba(255, 85, 0, 0.12)",
    "textPrimary":      "#FFFFFF",
    "textSecondary":    "#9A9A9A",
    "textPlaceholder":  "#484848",
    "error":            "#FF4444",
    "success":          "#22C55E",
    "successBg":        "rgba(34, 197, 94, 0.10)",
    "gold":             "#F59E0B",
    "goldBg":           "rgba(245, 158, 11, 0.10)",
    "goldBorder":       "rgba(245, 158, 11, 0.28)",
    "silver":           "#9CA3AF",
    "silverBg":         "rgba(156, 163, 175, 0.10)",
    "silverBorder":     "rgba(156, 163, 175, 0.25)",
    "bronze":           "#D97706",
    "bronzeBg":         "rgba(217, 119, 6, 0.10)",
    "bronzeBorder":     "rgba(217, 119, 6, 0.25)",
    "currentUserBg":    "rgba(255, 85, 0, 0.06)",
    "currentUserBorder":"rgba(255, 85, 0, 0.30)",
    "ratingColor":      "#FF5500",
    "unclassifiedBg":   "#0D0D0D"
  },
  "typography": {
    "fontFamily": "Inter, system-ui, -apple-system, sans-serif",
    "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap",
    "scale": {
      "xs":   "11px",
      "sm":   "13px",
      "base": "15px",
      "lg":   "18px",
      "xl":   "24px",
      "2xl":  "32px",
      "rank": "20px",
      "hero": "120px"
    },
    "weights": {
      "regular": 400,
      "medium":  500,
      "bold":    700,
      "black":   900
    },
    "lineHeight": 1.5
  },
  "spacing": {
    "1": "4px",  "2": "8px",  "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px",
    "12": "48px", "16": "64px"
  },
  "borderRadius": {
    "sm":   "4px",
    "md":   "8px",
    "lg":   "14px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 3px rgba(0,0,0,0.5)",
    "md": "0 4px 16px rgba(0,0,0,0.6)"
  },
  "components": {
    "leaderboardRow": {
      "bg":           "colors.surface",
      "border":       "colors.border",
      "borderRadius": "borderRadius.md",
      "padding":      "spacing.3 spacing.4",
      "currentUser": {
        "bg":         "colors.currentUserBg",
        "borderLeft": "colors.currentUserBorder"
      }
    },
    "rankBadge": {
      "gold":   { "color": "colors.gold",   "bg": "colors.goldBg",   "border": "colors.goldBorder" },
      "silver": { "color": "colors.silver", "bg": "colors.silverBg", "border": "colors.silverBorder" },
      "bronze": { "color": "colors.bronze", "bg": "colors.bronzeBg", "border": "colors.bronzeBorder" },
      "default": { "color": "colors.textSecondary", "bg": "transparent", "border": "colors.border" }
    }
  }
}
