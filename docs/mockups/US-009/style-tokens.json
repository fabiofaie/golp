{
  "extends": "US-005/style-tokens.json",
  "colors": {
    "bg":               "#0A0A0A",
    "surface":          "#141414",
    "surfaceElevated":  "#1F1F1F",
    "border":           "#2C2C2C",
    "accent":           "#FF5500",
    "accentHover":      "#E64D00",
    "accentDim":        "rgba(255, 85, 0, 0.12)",
    "textPrimary":      "#FFFFFF",
    "textSecondary":    "#9A9A9A",
    "textPlaceholder":  "#484848",
    "error":            "#FF4444",
    "errorBg":          "rgba(255, 68, 68, 0.10)",
    "errorBorder":      "rgba(255, 68, 68, 0.25)",
    "success":          "#22C55E",
    "successBg":        "rgba(34, 197, 94, 0.10)",
    "successBorder":    "rgba(34, 197, 94, 0.25)",
    "deltaPositive":    "#22C55E",
    "deltaPositiveBg":  "rgba(34, 197, 94, 0.08)",
    "deltaPositiveBorder": "rgba(34, 197, 94, 0.22)",
    "deltaNegative":    "#FF4444",
    "deltaNegativeBg":  "rgba(255, 68, 68, 0.08)",
    "deltaNegativeBorder": "rgba(255, 68, 68, 0.22)",
    "deltaZero":        "#9A9A9A",
    "deltaZeroBg":      "rgba(154, 154, 154, 0.08)",
    "deltaZeroBorder":  "rgba(154, 154, 154, 0.20)",
    "team1":            "#FF5500",
    "team1Bg":          "rgba(255, 85, 0, 0.08)",
    "team1Border":      "rgba(255, 85, 0, 0.25)",
    "team2":            "#0EA5E9",
    "team2Bg":          "rgba(14, 165, 233, 0.08)",
    "team2Border":      "rgba(14, 165, 233, 0.25)",
    "pendingColor":     "#F59E0B",
    "pendingBg":        "rgba(245, 158, 11, 0.10)",
    "pendingBorder":    "rgba(245, 158, 11, 0.25)",
    "disputedColor":    "#FF4444",
    "disputedBg":       "rgba(255, 68, 68, 0.10)",
    "disputedBorder":   "rgba(255, 68, 68, 0.25)",
    "tabActive":        "#FF5500",
    "tabActiveBg":      "rgba(255, 85, 0, 0.10)",
    "tabInactive":      "#484848"
  },
  "typography": {
    "fontFamily": "Inter, system-ui, -apple-system, sans-serif",
    "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap",
    "scale": {
      "xs":   "11px",
      "sm":   "13px",
      "base": "15px",
      "lg":   "18px",
      "xl":   "24px",
      "2xl":  "32px",
      "delta": "28px",
      "hero": "120px"
    },
    "weights": {
      "regular": 400,
      "medium":  500,
      "bold":    700,
      "black":   900
    },
    "lineHeight": 1.5
  },
  "spacing": {
    "1": "4px",  "2": "8px",  "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px",
    "12": "48px", "16": "64px"
  },
  "borderRadius": {
    "sm":   "4px",
    "md":   "8px",
    "lg":   "14px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 3px rgba(0,0,0,0.5)",
    "md": "0 4px 16px rgba(0,0,0,0.6)"
  },
  "components": {
    "matchCard": {
      "bg":           "colors.surface",
      "border":       "colors.border",
      "borderRadius": "borderRadius.lg",
      "padding":      "spacing.4"
    },
    "deltaBadge": {
      "positive": {
        "color":      "colors.deltaPositive",
        "bg":         "colors.deltaPositiveBg",
        "border":     "colors.deltaPositiveBorder",
        "fontSize":   "typography.scale.delta"
      },
      "negative": {
        "color":      "colors.deltaNegative",
        "bg":         "colors.deltaNegativeBg",
        "border":     "colors.deltaNegativeBorder",
        "fontSize":   "typography.scale.delta"
      },
      "zero": {
        "color":      "colors.deltaZero",
        "bg":         "colors.deltaZeroBg",
        "border":     "colors.deltaZeroBorder",
        "fontSize":   "typography.scale.delta"
      }
    },
    "tabBar": {
      "bg":           "colors.surface",
      "borderBottom": "colors.border",
      "activeColor":  "colors.tabActive",
      "activeBg":     "colors.tabActiveBg",
      "inactiveColor":"colors.tabInactive"
    }
  }
}
