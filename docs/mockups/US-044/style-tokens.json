{
  "meta": {
    "story": "US-044",
    "title": "Storico partite personale nella dashboard",
    "source": "Allineato a docs/mockups/dashboard/shared.css"
  },
  "colors": {
    "bg":               "#0A0A0A",
    "surface":          "#141414",
    "surface-elevated": "#1F1F1F",
    "border":           "#2C2C2C",
    "accent":           "#FF5500",
    "text-primary":     "#FFFFFF",
    "text-secondary":   "#9A9A9A",
    "text-placeholder": "#484848",
    "win":              "#22C55E",
    "win-bg":           "rgba(34,197,94,0.10)",
    "loss":             "#FF4444",
    "loss-bg":          "rgba(255,68,68,0.10)",
    "pending":          "#F59E0B",
    "pending-bg":       "rgba(245,158,11,0.10)",
    "disputed":         "#FF4444",
    "disputed-bg":      "rgba(255,68,68,0.10)"
  },
  "typography": {
    "fontFamily": "'Inter', system-ui, -apple-system, sans-serif",
    "sizes": {
      "xs":   "11px",
      "sm":   "13px",
      "base": "15px",
      "lg":   "18px"
    },
    "weights": {
      "regular": 400,
      "medium":  500,
      "bold":    700,
      "black":   900
    }
  },
  "spacing": {
    "1":  "4px",  "2": "8px",  "3": "12px", "4": "16px",
    "5": "20px",  "6": "24px", "8": "32px"
  },
  "radii": {
    "sm":   "4px",
    "md":   "8px",
    "lg":   "14px",
    "full": "9999px"
  },
  "components": {
    "filterTab": {
      "height": "32px",
      "borderRadius": "full",
      "activeBackground": "surface-elevated",
      "activeColor": "text-primary",
      "inactiveColor": "text-secondary"
    },
    "matchRow": {
      "background": "surface",
      "border": "1px solid border",
      "borderRadius": "md",
      "borderLeftWidth": "3px",
      "borderLeftColors": {
        "win":      "win",
        "loss":     "loss",
        "pending":  "pending",
        "disputed": "disputed"
      },
      "padding": "12px 16px"
    },
    "deltaValue": {
      "fontSize":   "lg",
      "fontWeight": "black",
      "colorPos": "win",
      "colorNeg": "loss",
      "colorNone": "text-placeholder"
    },
    "resultPill": {
      "fontSize":   "xs",
      "fontWeight": "black",
      "borderRadius": "sm",
      "variants": {
        "win":  { "background": "win-bg",  "color": "win"  },
        "loss": { "background": "loss-bg", "color": "loss" },
        "dash": { "background": "none",    "color": "text-placeholder" }
      }
    },
    "statusPip": {
      "fontSize": "xs",
      "borderRadius": "full",
      "variants": {
        "confirmed": { "background": "win-bg",      "color": "win"      },
        "pending":   { "background": "pending-bg",  "color": "pending"  },
        "disputed":  { "background": "disputed-bg", "color": "disputed" }
      }
    }
  }
}
