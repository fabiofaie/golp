{
  "$schema": "golp-design-tokens/v1",
  "description": "Design tokens for US-024 — PWA install banner + per-platform guide. Reuses GOLP dark sport theme (source: docs/mockups/US-001/style-tokens.json), extended only with install-guide specific tokens.",

  "colors": {
    "bg":               "#0A0A0A",
    "surface":          "#141414",
    "surfaceElevated":  "#1F1F1F",
    "border":           "#2C2C2C",
    "accent":           "#FF5500",
    "accentHover":      "#E64D00",
    "accentDim":        "rgba(255, 85, 0, 0.12)",
    "textPrimary":      "#FFFFFF",
    "textSecondary":    "#9A9A9A",
    "textPlaceholder":  "#484848",
    "success":          "#22C55E",
    "successBg":        "rgba(34, 197, 94, 0.10)",

    "installStepNumberBg":   "#1F1F1F",
    "installStepNumberText": "#FF5500",
    "installBadgeBg":        "rgba(255, 85, 0, 0.12)",
    "installBadgeBorder":    "rgba(255, 85, 0, 0.30)"
  },

  "typography": {
    "fontFamily":  "'Inter', system-ui, -apple-system, sans-serif",
    "fontSizes": {
      "xs":   "11px",
      "sm":   "13px",
      "base": "15px",
      "lg":   "18px",
      "xl":   "24px"
    },
    "fontWeights": {
      "regular": 400,
      "medium":  500,
      "bold":    700
    },
    "lineHeight": 1.5
  },

  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },

  "radius": {
    "sm": "8px",
    "md": "14px",
    "lg": "20px",
    "pill": "999px"
  },

  "shadow": {
    "banner": "0 -4px 24px rgba(0, 0, 0, 0.45)",
    "modal":  "0 8px 40px rgba(0, 0, 0, 0.55)"
  },

  "components": {
    "installBanner": {
      "position": "fixed bottom sheet, safe-area aware",
      "background": "colors.surfaceElevated",
      "border": "1px solid colors.border",
      "borderRadius": "radius.lg (top corners only)"
    },
    "installGuide": {
      "layout": "full-screen modal on mobile",
      "background": "colors.bg",
      "stepNumber": {
        "background": "colors.installStepNumberBg",
        "color": "colors.installStepNumberText",
        "shape": "circle, 28px"
      },
      "platformBadge": {
        "background": "colors.installBadgeBg",
        "border": "1px solid colors.installBadgeBorder",
        "borderRadius": "radius.pill"
      }
    }
  }
}
