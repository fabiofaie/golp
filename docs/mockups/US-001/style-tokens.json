{
  "$schema": "golp-design-tokens/v1",
  "description": "Design tokens for GOLP — dark sport theme. Source of truth for /eq-implement.",

  "colors": {
    "bg":               "#0A0A0A",
    "surface":          "#141414",
    "surfaceElevated":  "#1F1F1F",
    "border":           "#2C2C2C",
    "accent":           "#FF5500",
    "accentHover":      "#E64D00",
    "accentDim":        "rgba(255, 85, 0, 0.12)",
    "textPrimary":      "#FFFFFF",
    "textSecondary":    "#9A9A9A",
    "textPlaceholder":  "#484848",
    "error":            "#FF4444",
    "errorBg":          "rgba(255, 68, 68, 0.10)",
    "success":          "#22C55E",
    "successBg":        "rgba(34, 197, 94, 0.10)",
    "warning":          "#F59E0B"
  },

  "typography": {
    "fontFamily":       "'Inter', system-ui, -apple-system, sans-serif",
    "fontSizes": {
      "xs":   "11px",
      "sm":   "13px",
      "base": "15px",
      "lg":   "18px",
      "xl":   "24px",
      "2xl":  "32px",
      "hero": "120px"
    },
    "fontWeights": {
      "regular": 400,
      "medium":  500,
      "bold":    700,
      "black":   900
    },
    "lineHeight": 1.5
  },

  "spacing": {
    "1":  "4px",
    "2":  "8px",
    "3":  "12px",
    "4":  "16px",
    "5":  "20px",
    "6":  "24px",
    "8":  "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },

  "borderRadius": {
    "sm":   "4px",
    "md":   "8px",
    "lg":   "14px",
    "full": "9999px"
  },

  "shadows": {
    "sm": "0 1px 3px rgba(0,0,0,0.5)",
    "md": "0 4px 16px rgba(0,0,0,0.6)"
  },

  "components": {
    "inputHeight":   "52px",
    "buttonHeight":  "52px",
    "pageMaxWidth":  "390px",
    "pagePadding":   "24px"
  },

  "brandElement": {
    "name": "bg-deco",
    "description": "The number '1000' (starting ELO rating) rendered at large scale with 5% opacity in accent color, positioned top-right of auth screens. Communicates the product purpose without copy.",
    "value": "1000",
    "fontSize": "120px",
    "opacity": 0.05,
    "color": "#FF5500",
    "fontWeight": 900
  }
}
