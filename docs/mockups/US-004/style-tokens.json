{
  "extends": "US-003/style-tokens.json",
  "colors": {
    "bg":               "#0A0A0A",
    "surface":          "#141414",
    "surfaceElevated":  "#1F1F1F",
    "border":           "#2C2C2C",
    "accent":           "#FF5500",
    "accentHover":      "#E64D00",
    "accentDim":        "rgba(255, 85, 0, 0.12)",
    "textPrimary":      "#FFFFFF",
    "textSecondary":    "#9A9A9A",
    "textPlaceholder":  "#484848",
    "error":            "#FF4444",
    "errorBg":          "rgba(255, 68, 68, 0.10)",
    "success":          "#22C55E",
    "successBg":        "rgba(34, 197, 94, 0.10)",
    "team1":            "#FF5500",
    "team1Bg":          "rgba(255, 85, 0, 0.08)",
    "team1Border":      "rgba(255, 85, 0, 0.25)",
    "team2":            "#0EA5E9",
    "team2Bg":          "rgba(14, 165, 233, 0.08)",
    "team2Border":      "rgba(14, 165, 233, 0.25)",
    "scoreInputBg":     "#0F0F0F",
    "scoreInputBorder": "#3A3A3A",
    "pendingColor":     "#F59E0B",
    "pendingBg":        "rgba(245, 158, 11, 0.10)",
    "pendingBorder":    "rgba(245, 158, 11, 0.25)"
  },
  "typography": {
    "fontFamily": "Inter, system-ui, -apple-system, sans-serif",
    "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap",
    "scale": {
      "xs":    "11px",
      "sm":    "13px",
      "base":  "15px",
      "lg":    "18px",
      "xl":    "24px",
      "2xl":   "32px",
      "score": "40px",
      "hero":  "120px"
    },
    "weights": {
      "regular": 400,
      "medium":  500,
      "bold":    700,
      "black":   900
    },
    "lineHeight": 1.5
  },
  "spacing": {
    "1": "4px",  "2": "8px",  "3": "12px", "4": "16px",
    "5": "20px", "6": "24px", "8": "32px", "10": "40px",
    "12": "48px", "16": "64px"
  },
  "borderRadius": {
    "sm":   "4px",
    "md":   "8px",
    "lg":   "14px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 3px rgba(0,0,0,0.5)",
    "md": "0 4px 16px rgba(0,0,0,0.6)"
  },
  "components": {
    "teamBlock": {
      "bg":             "colors.surface",
      "border":         "colors.border",
      "borderLeft1":    "colors.team1",
      "borderLeft2":    "colors.team2",
      "borderRadius":   "borderRadius.lg",
      "padding":        "spacing.4 spacing.5"
    },
    "playerSlot": {
      "bg":             "colors.surfaceElevated",
      "border":         "colors.border",
      "borderFilled1":  "colors.team1Border",
      "bgFilled1":      "colors.team1Bg",
      "borderFilled2":  "colors.team2Border",
      "bgFilled2":      "colors.team2Bg",
      "borderRadius":   "borderRadius.md",
      "padding":        "spacing.3 spacing.4",
      "avatarSize":     "32px"
    },
    "scoreInput": {
      "bg":             "colors.scoreInputBg",
      "border":         "colors.scoreInputBorder",
      "borderFocused":  "colors.accent",
      "borderTopT1":    "colors.team1",
      "borderTopT2":    "colors.team2",
      "fontSize":       "typography.scale.xl",
      "fontWeight":     "typography.weights.black",
      "borderRadius":   "borderRadius.md",
      "textAlign":      "center"
    },
    "scoreSingleInput": {
      "fontSize":       "typography.scale.score",
      "fontWeight":     "typography.weights.black"
    },
    "addSetButton": {
      "bg":             "transparent",
      "border":         "1px dashed colors.border",
      "borderHover":    "colors.accent",
      "color":          "colors.textSecondary",
      "colorHover":     "colors.accent",
      "borderRadius":   "borderRadius.md",
      "padding":        "spacing.3"
    },
    "pendingBadge": {
      "bg":             "colors.pendingBg",
      "border":         "colors.pendingBorder",
      "color":          "colors.pendingColor",
      "borderRadius":   "borderRadius.full",
      "fontSize":       "typography.scale.xs",
      "fontWeight":     "typography.weights.bold"
    },
    "successCard": {
      "bg":             "colors.surface",
      "border":         "rgba(34, 197, 94, 0.25)",
      "borderRadius":   "borderRadius.lg",
      "padding":        "spacing.6",
      "titleColor":     "colors.success"
    }
  }
}
