      "base":   "15px",
      "lg":     "18px",
      "xl":     "24px",
      "2xl":    "32px",
      "rating": "64px"
    },
    "weights": {
      "regular": 400,
      "medium":  500,
      "bold":    700,
      "black":   900
    }
  },
  "spacing": {
    "1":  "4px",  "2":  "8px",  "3":  "12px", "4":  "16px",
