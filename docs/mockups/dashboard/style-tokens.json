{
  "source": "docs/mockups/dashboard/shared.css",
  "colors": {
    "bg":               "#0A0A0A",
    "surface":          "#141414",
    "surface-elevated": "#1F1F1F",
    "border":           "#2C2C2C",
    "accent":           "#FF5500",
    "accent-hover":     "#E64D00",
    "accent-dim":       "rgba(255,85,0,0.12)",
    "text-primary":     "#FFFFFF",
    "text-secondary":   "#9A9A9A",
    "text-placeholder": "#484848",
    "error":            "#FF4444",
    "success":          "#22C55E",
    "pending":          "#F59E0B",
    "team1":            "#FF5500",
    "team2":            "#0EA5E9",
